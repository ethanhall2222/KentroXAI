<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Trust Card</title>
  <style>
    :root {
      --bg: #ececef;
      --card: #f4f5f8;
      --card-border: #d8dbe3;
      --ink: #1b2230;
      --muted: #5f6778;
      --chip-pass-bg: #d6f0df;
      --chip-pass-text: #0f6c3b;
      --chip-blue-bg: #dbe8ff;
      --chip-blue-text: #1d4ed8;
      --chip-purple-bg: #ece5ff;
      --chip-purple-text: #5b21b6;
      --chip-amber-bg: #f9ebca;
      --chip-amber-text: #9a5a00;
      --chip-sky-bg: #dceef9;
      --chip-sky-text: #075985;
      --ring: #2b64df;
      --button: #10182e;
      --button-border: #1c2949;
      --shadow: 0 1px 0 rgba(17, 24, 39, 0.08), 0 10px 24px rgba(17, 24, 39, 0.07);
    }

    * { box-sizing: border-box; }
    body {
      margin: 0;
      background: radial-gradient(circle at top right, #f7f8fc 0%, var(--bg) 42%, #e8e9ee 100%);
      color: var(--ink);
      font-family: "Avenir Next", "Segoe UI", Helvetica, Arial, sans-serif;
      padding: 18px;
    }

    .frame {
      max-width: 1460px;
      margin: 0 auto;
    }

    .title {
      font-size: 40px;
      letter-spacing: -0.9px;
      line-height: 1;
      font-weight: 900;
      margin: 0 0 2px;
    }

    .subtitle {
      margin: 0 0 14px;
      font-size: 16px;
      color: #3f4758;
      font-weight: 600;
    }

    .trust-card {
      border: 2px solid var(--card-border);
      border-radius: 40px;
      background: var(--card);
      box-shadow: var(--shadow);
      padding: 18px 22px 18px;
    }

    .card-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 16px;
      border-bottom: 1px solid #d9dde7;
      padding-bottom: 10px;
      margin-bottom: 10px;
    }

    .card-head h2 {
      font-size: 34px;
      line-height: 1;
      margin: 0 0 6px;
      font-weight: 900;
      letter-spacing: -0.5px;
    }

    .request {
      margin: 0;
      font-size: 16px;
      color: #353f50;
      line-height: 1.35;
      max-width: 920px;
    }

    .evidence {
      font-size: 18px;
      font-weight: 700;
      color: #4c5568;
      white-space: nowrap;
      padding-top: 4px;
    }

    .chips {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin: 6px 0 14px;
    }

    .chip {
      padding: 7px 14px;
      border-radius: 9px;
      font-size: 14px;
      font-weight: 800;
      line-height: 1;
      letter-spacing: 0.1px;
      border: 1px solid rgba(0, 0, 0, 0.06);
    }

    .chip.pass { background: var(--chip-pass-bg); color: var(--chip-pass-text); }
    .chip.blue { background: var(--chip-blue-bg); color: var(--chip-blue-text); }
    .chip.purple { background: var(--chip-purple-bg); color: var(--chip-purple-text); }
    .chip.amber { background: var(--chip-amber-bg); color: var(--chip-amber-text); }
    .chip.sky { background: var(--chip-sky-bg); color: var(--chip-sky-text); }

    .layout {
      display: grid;
      grid-template-columns: 220px minmax(0, 1fr);
      gap: 18px;
      align-items: start;
    }

    .score-wrap {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .score-details {
      margin: 0;
    }

    .score-details summary {
      list-style: none;
    }

    .score-details summary::-webkit-details-marker {
      display: none;
    }

    .ring-toggle {
      cursor: pointer;
      user-select: none;
      transition: transform 0.16s ease, box-shadow 0.16s ease;
    }

    .ring-toggle:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(43, 100, 223, 0.12);
    }

    .ring-note {
      margin: 8px 0 0;
      font-size: 12px;
      font-weight: 700;
      color: var(--muted);
      text-align: center;
    }

    .score-breakdown {
      margin-top: 10px;
      padding: 12px 14px;
      border-radius: 18px;
      border: 1px solid #d3d8e4;
      background: #eef3ff;
    }

    .score-breakdown h3 {
      margin: 0 0 6px;
      font-size: 16px;
      font-weight: 900;
      letter-spacing: -0.2px;
    }

    .score-breakdown ul {
      margin: 0;
      padding-left: 18px;
    }

    .score-breakdown li {
      font-size: 13px;
      line-height: 1.45;
      color: #253042;
    }

    .score-breakdown .breakdown-note {
      margin: 0 0 8px;
      font-size: 12px;
      font-weight: 700;
      color: var(--muted);
    }

    .pillar-detail {
      margin: 6px 0;
      border: 1px solid #d4daea;
      border-radius: 12px;
      background: #f8faff;
      overflow: hidden;
    }

    .pillar-summary {
      cursor: pointer;
      padding: 8px 10px;
      font-size: 13px;
      font-weight: 800;
      list-style: none;
    }

    .pillar-summary::-webkit-details-marker {
      display: none;
    }

    .pillar-summary::after {
      content: "Expand";
      float: right;
      font-size: 11px;
      font-weight: 700;
      color: var(--muted);
    }

    .pillar-detail[open] .pillar-summary::after {
      content: "Collapse";
    }

    .pillar-meta {
      margin: 0;
      padding: 0 12px 10px 28px;
    }

    .pillar-meta li {
      font-size: 12px;
      line-height: 1.45;
      color: #314057;
    }

    .ring {
      width: 200px;
      height: 200px;
      border-radius: 50%;
      border: 6px solid var(--ring);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      background: #f9faff;
    }

    .ring .num {
      font-size: 60px;
      font-weight: 900;
      line-height: 1;
      margin: 0;
      letter-spacing: -1px;
    }

    .ring .label {
      margin: 8px 0 0;
      font-size: 18px;
      color: #4a5568;
      font-weight: 600;
    }

    .tier-box {
      background: #eef0f5;
      border: 1px solid #d3d8e4;
      border-radius: 18px;
      padding: 12px 14px;
      min-height: 170px;
    }

    .tier-label {
      font-size: 14px;
      color: #6a7283;
      margin: 0 0 4px;
      font-weight: 700;
    }

    .tier-value {
      font-size: 24px;
      margin: 0 0 8px;
      font-weight: 900;
      letter-spacing: -0.4px;
    }

    .minor-label {
      font-size: 13px;
      color: #6a7283;
      margin: 0 0 3px;
      font-weight: 700;
    }

    .minor-value {
      font-size: 22px;
      margin: 0 0 8px;
      font-weight: 800;
    }

    .review-note {
      font-size: 15px;
      color: #991b1b;
      font-weight: 900;
      margin: 4px 0 0;
      padding: 10px 12px;
      border-radius: 12px;
      background: #fee2e2;
      border: 1px solid #fca5a5;
      line-height: 1.35;
    }

    .sections h3 {
      margin: 0 0 4px;
      font-size: 22px;
      letter-spacing: -0.3px;
      font-weight: 900;
    }

    .sections { display: grid; gap: 10px; }

    .sections ul {
      margin: 0;
      padding-left: 18px;
    }

    .sections li {
      font-size: 14px;
      line-height: 1.45;
      margin: 1px 0;
      color: #253042;
    }

    .actions {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      border-top: 1px solid #d9dde7;
      margin-top: 12px;
      padding-top: 10px;
    }

    .btn-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .btn {
      background: var(--button);
      color: #f9fbff;
      border: 1px solid var(--button-border);
      border-radius: 10px;
      padding: 8px 14px;
      font-size: 13px;
      font-weight: 800;
      min-width: 124px;
      text-align: center;
    }

    .footnote {
      margin: 0;
      font-size: 12px;
      line-height: 1.35;
      color: #5b6475;
      max-width: 470px;
    }

    @media (max-width: 1280px) {
      .title { font-size: 34px; }
      .subtitle { font-size: 15px; }
      .card-head h2 { font-size: 30px; }
      .request { font-size: 15px; }
      .evidence { font-size: 16px; }
      .chip { font-size: 13px; }
      .layout { grid-template-columns: 220px minmax(0, 1fr); }
      .ring { width: 180px; height: 180px; }
      .ring .num { font-size: 54px; }
      .ring .label { font-size: 17px; }
      .tier-label, .minor-label { font-size: 13px; }
      .tier-value, .minor-value { font-size: 20px; }
      .review-note { font-size: 14px; }
      .sections h3 { font-size: 20px; }
      .sections li { font-size: 13px; }
      .btn { font-size: 12px; min-width: 116px; }
      .footnote { font-size: 11px; }
    }

    @media (max-width: 930px) {
      body { padding: 12px; }
      .trust-card { border-radius: 24px; padding: 16px; }
      .title { font-size: 32px; }
      .subtitle { font-size: 15px; }
      .card-head { flex-direction: column; gap: 8px; }
      .card-head h2 { font-size: 32px; }
      .request { font-size: 15px; }
      .evidence { font-size: 16px; }
      .chip { font-size: 13px; }
      .layout { grid-template-columns: 1fr; gap: 16px; }
      .score-wrap { flex-direction: row; flex-wrap: wrap; }
      .ring { width: 160px; height: 160px; }
      .ring .num { font-size: 52px; }
      .ring .label { font-size: 17px; }
      .tier-box { flex: 1; min-width: 220px; min-height: unset; }
      .tier-label, .minor-label { font-size: 13px; }
      .tier-value, .minor-value { font-size: 23px; }
      .review-note { font-size: 14px; }
      .sections h3 { font-size: 24px; }
      .sections li { font-size: 15px; }
      .actions { flex-direction: column; align-items: stretch; }
      .btn-row { width: 100%; }
      .btn { flex: 1; min-width: 0; }
      .footnote { max-width: unset; font-size: 13px; }
    }
  </style>
</head>
<body>
  {% set ns = namespace(failed_metrics=0) %}
  {% for m in metric_results %}
    {% if m.passed is sameas false %}
      {% set ns.failed_metrics = ns.failed_metrics + 1 %}
    {% endif %}
  {% endfor %}

  {% set display_risk_tier = deployment_risk_tier or risk_tier %}
  {% set pedigree = display_risk_tier | upper %}
  {% if overall_status == "pass" %}
    {% set policy_text = "Policy PASS" %}
  {% elif overall_status == "fail" %}
    {% set policy_text = "Policy FAIL" %}
  {% else %}
    {% set policy_text = "Policy REVIEW" %}
  {% endif %}

  <div class="frame">
    <h1 class="title">Trust Card (User-Facing)</h1>
    <p class="subtitle">Compact, evidence-backed trust summary returned with every AI output</p>

    <section class="trust-card">
      <div class="card-head">
        <div>
          <h2>Trust Card</h2>
          <p class="request"><strong>Request:</strong> "{{ executive_summary }}"</p>
        </div>
        <p class="evidence">Evidence Pack: {{ run_id }}</p>
      </div>

      <div class="chips">
        <span class="chip pass">{{ policy_text }}</span>
        <span class="chip blue">{{ artifact_signal.evidence_label }}</span>
        <span class="chip purple">Pedigree {{ pedigree }}</span>
        <span class="chip amber">{{ artifact_signal.trace_label }}</span>
        <span class="chip sky">{{ artifact_signal.security_label }}</span>
      </div>

      <div class="layout">
        <div class="score-wrap">
          <details class="score-details">
            <summary>
              <div class="ring ring-toggle">
                <p class="num">{{ card_score.display_score_pct if card_score.display_score_pct is not none else "N/A" }}</p>
                <p class="label">{{ card_score.label }}</p>
              </div>
              <p class="ring-note">Click for pillar breakdown</p>
            </summary>
            <div class="score-breakdown">
              <h3>Pillar Breakdown</h3>
              <p class="breakdown-note">
                Underlying control score: {{ card_score.control_score_pct if card_score.control_score_pct is not none else "N/A" }}.
                Click each pillar to see the formula, weighting, and control-score contribution.
              </p>
              <div>
                {% if pillar_breakdowns %}
                {% for pillar_name, breakdown in pillar_breakdowns.items() %}
                <details class="pillar-detail">
                  <summary class="pillar-summary">{{ pillar_name | title }}: {{ breakdown.pillar_score }}</summary>
                  <ul class="pillar-meta">
                    <li>Controls passed: {{ breakdown.control_passed }}/{{ breakdown.control_total }}</li>
                    <li>Control pass rate: {{ breakdown.control_pass_rate }}</li>
                    {% if breakdown.redteam_pass_rate is defined %}
                    <li>Red-team pass rate: {{ breakdown.redteam_pass_rate }}</li>
                    {% endif %}
                    <li>Formula: {{ breakdown.formula }}</li>
                    <li>Pillar score: {{ breakdown.pillar_score }}</li>
                    <li>Control score weight: {{ breakdown.trust_weight }}</li>
                    <li>Weighted contribution to control score: {{ breakdown.trust_contribution }}</li>
                  </ul>
                </details>
                {% endfor %}
                {% else %}
                <ul>
                  <li>Pillar scores are not available for this run.</li>
                </ul>
                {% endif %}
              </div>
            </div>
          </details>

          <div class="tier-box">
            <p class="tier-label">Risk Tier</p>
            <p class="tier-value">{{ display_risk_tier | upper }}</p>

            <p class="minor-label">Decision Tier</p>
            <p class="minor-value">{{ risk_tier }}</p>

            <p class="minor-label">Review Status</p>
            <p class="minor-value">{{ overall_status | replace("_", " ") | title }}</p>

            <p class="review-note">{{ card_score.status_note }}</p>
          </div>
        </div>

        <div class="sections">
          <div>
            <h3>Evaluation Summary</h3>
            <ul>
              <li>Evaluation checks: {{ metric_summary.passed }} of {{ metric_summary.total }} passed{% if metric_summary.failed %}; {{ metric_summary.failed }} blocking issue{% if metric_summary.failed != 1 %}s{% endif %} remain{% endif %}.</li>
              <li>Metric pass rate: {{ "%.0f"|format((metric_summary.pass_rate * 100)) if metric_summary.pass_rate is not none else "N/A" }}%.</li>
              <li>Fairness checks included: {{ "Yes" if metric_summary.fairness_metrics else "No" }}.</li>
              <li>Reasoning evidence available: {{ "Yes" if artifact_presence.reasoning_report else "No" }}.</li>
            </ul>
          </div>

          <div>
            <h3>Governance Trace</h3>
            <ul>
              <li>Run ID: {{ run_id }} | Project: {{ project_name }}</li>
              <li>Governance tier: {{ risk_tier }} | Deployment tier: {{ display_risk_tier | upper }}.</li>
              <li>Stage gates: {% for gate, status in stage_gate_status.items() %}{{ gate | replace("_", " ") | title }}={{ status | upper }}{% if not loop.last %}; {% endif %}{% endfor %}</li>
              <li>Evidence package complete: {{ "Yes" if evidence_completeness >= 90 else "No" }} ({{ "%.0f"|format(evidence_completeness) }}%).</li>
            </ul>
          </div>

          <div>
            <h3>Security Findings</h3>
            <ul>
              <li>Blocking threshold: {{ severity_threshold | upper }}.</li>
              <li>Red-team findings: {{ redteam_summary.high + redteam_summary.critical }} high-severity blocker{% if (redteam_summary.high + redteam_summary.critical) != 1 %}s{% endif %}, {{ redteam_summary.medium }} medium, {{ redteam_summary.low }} low.</li>
              <li>Release decision: {{ go_no_go | upper }} based on stage-gate outcomes.</li>
            </ul>
          </div>

          <div>
            <h3>Actions Required</h3>
            <ul>
              {% for action in required_actions %}
              <li>{{ action }}</li>
              {% endfor %}
              <li>Documentation completeness: {{ "%.0f"|format(evidence_completeness) }}% of required outputs.</li>
            </ul>
          </div>

          <div>
            <h3>Control Summary</h3>
            <ul>
              {% if pillar_scores %}
              <li>Underlying control score: {{ card_score.control_score_pct if card_score.control_score_pct is not none else "N/A" }}.</li>
              <li>Security controls: {{ "%.0f"|format(pillar_scores.security * 100) }}%.</li>
              <li>Reliability, transparency, and governance controls: {{ "%.0f"|format(pillar_scores.reliability * 100) }}%, {{ "%.0f"|format(pillar_scores.transparency * 100) }}%, and {{ "%.0f"|format(pillar_scores.governance * 100) }}%.</li>
              {% else %}
              <li>Not available for this run.</li>
              {% endif %}
            </ul>
          </div>
        </div>
      </div>

      <div class="actions">
        <p class="footnote">This card travels with the output as an auditable evidence link for governance review.</p>
      </div>
    </section>
  </div>
</body>
</html>
