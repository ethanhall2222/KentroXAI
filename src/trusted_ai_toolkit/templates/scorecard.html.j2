<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Answer Trust Card</title>
  <style>
    :root {
      --bg: #f3f5f7;
      --card: rgba(255, 255, 255, 0.88);
      --card-border: rgba(16, 24, 40, 0.08);
      --ink: #0f1728;
      --muted: #5f6b7a;
      --brand: #176f76;
      --brand-deep: #114f55;
      --brand-soft: rgba(23, 111, 118, 0.08);
      --chip-pass-bg: rgba(16, 185, 129, 0.10);
      --chip-pass-text: #166a4a;
      --chip-blue-bg: rgba(37, 99, 235, 0.08);
      --chip-blue-text: #2547a8;
      --chip-purple-bg: rgba(23, 111, 118, 0.08);
      --chip-purple-text: #155e75;
      --chip-amber-bg: rgba(217, 119, 6, 0.10);
      --chip-amber-text: #8a5100;
      --chip-sky-bg: rgba(14, 165, 233, 0.08);
      --chip-sky-text: #0f5f7a;
      --ring: #176f76;
      --button: #111827;
      --button-border: rgba(17, 24, 39, 0.10);
      --shadow: 0 8px 24px rgba(15, 23, 40, 0.06), 0 1px 2px rgba(15, 23, 40, 0.04);
    }

    * { box-sizing: border-box; }
    body {
      margin: 0;
      background:
        radial-gradient(circle at top right, rgba(23, 111, 118, 0.05) 0%, rgba(23, 111, 118, 0) 28%),
        radial-gradient(circle at top left, rgba(37, 99, 235, 0.04) 0%, rgba(37, 99, 235, 0) 24%),
        linear-gradient(180deg, #fafbfc 0%, var(--bg) 100%);
      color: var(--ink);
      font-family: "SF Pro Display", "SF Pro Text", "Segoe UI Variable", "Segoe UI", Helvetica, Arial, sans-serif;
      padding: 24px;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }

    .frame {
      max-width: 1460px;
      margin: 0 auto;
    }

    .title {
      font-size: 40px;
      letter-spacing: -0.9px;
      line-height: 1;
      font-weight: 900;
      margin: 0 0 4px;
      color: var(--brand-deep);
    }

    .subtitle {
      margin: 0 0 14px;
      font-size: 16px;
      color: var(--muted);
      font-weight: 700;
    }

    .trust-card {
      border: 1px solid var(--card-border);
      border-radius: 30px;
      background: var(--card);
      box-shadow: var(--shadow);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      padding: 20px 24px 18px;
      position: relative;
      overflow: hidden;
    }

    .trust-card::before {
      content: "";
      position: absolute;
      inset: 0 auto auto 0;
      width: 100%;
      height: 4px;
      background: linear-gradient(90deg, rgba(23, 111, 118, 0.9) 0%, rgba(42, 139, 146, 0.55) 55%, rgba(17, 79, 85, 0.85) 100%);
    }

    .brand-bar {
      display: flex;
      align-items: flex-end;
      gap: 14px;
      margin: 0 0 16px;
      flex-wrap: nowrap;
      overflow: visible;
    }

    .brand-logo {
      display: block;
      width: min(240px, 100%);
      height: auto;
      object-fit: contain;
    }

    .brand-lockup {
      display: flex;
      flex-direction: column;
      gap: 8px;
      min-width: 0;
      width: 100%;
    }

    .brand-mark {
      width: 96px;
      height: 96px;
      border-radius: 28px;
      background:
        radial-gradient(circle at center, rgba(247, 250, 249, 0.98) 0 24%, transparent 26%),
        linear-gradient(45deg, transparent 37%, #1698c7 37% 48%, #0a6f86 48% 63%, transparent 63%),
        linear-gradient(-45deg, transparent 37%, #2bc0ff 37% 48%, #0a6f86 48% 63%, transparent 63%);
      box-shadow:
        inset 0 0 0 4px rgba(23, 111, 118, 0.10),
        0 10px 22px rgba(23, 111, 118, 0.12);
      flex: 0 0 auto;
    }

    .brand-copy {
      display: flex;
      flex-direction: column;
      gap: 4px;
      min-width: 0;
    }

    .brand-name {
      margin: 0;
      font-size: 72px;
      line-height: 0.95;
      font-weight: 900;
      letter-spacing: 0.08em;
      color: var(--brand);
      white-space: nowrap;
    }

    .brand-tag {
      margin: 0;
      font-size: 13px;
      line-height: 1.2;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
      font-weight: 700;
      white-space: nowrap;
    }

    .card-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 16px;
      border-bottom: 1px solid rgba(15, 23, 40, 0.07);
      padding-bottom: 12px;
      margin-bottom: 12px;
    }

    .card-head h2 {
      font-size: 34px;
      line-height: 1;
      margin: 0 0 6px;
      font-weight: 700;
      letter-spacing: -0.03em;
      color: var(--ink);
    }

    .request {
      margin: 0;
      font-size: 16px;
      color: var(--ink);
      line-height: 1.35;
      max-width: 920px;
    }

    .evidence {
      font-size: 16px;
      font-weight: 600;
      color: var(--muted);
      white-space: nowrap;
      padding-top: 4px;
    }

    .chips {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin: 6px 0 14px;
    }

    .chip {
      padding: 8px 12px;
      border-radius: 999px;
      font-size: 13px;
      font-weight: 700;
      line-height: 1;
      letter-spacing: 0.01em;
      border: 1px solid rgba(15, 23, 40, 0.06);
    }

    .hint {
      cursor: help;
    }

    .chip.pass { background: var(--chip-pass-bg); color: var(--chip-pass-text); }
    .chip.blue { background: var(--chip-blue-bg); color: var(--chip-blue-text); }
    .chip.purple { background: var(--chip-purple-bg); color: var(--chip-purple-text); }
    .chip.amber { background: var(--chip-amber-bg); color: var(--chip-amber-text); }
    .chip.sky { background: var(--chip-sky-bg); color: var(--chip-sky-text); }

    .layout {
      display: grid;
      grid-template-columns: 240px minmax(0, 1fr);
      gap: 24px;
      align-items: start;
    }

    .score-wrap {
      display: flex;
      flex-direction: column;
      gap: 12px;
      align-items: center;
    }

    .ring-note {
      margin: 0;
      font-size: 13px;
      font-weight: 600;
      color: var(--muted);
      text-align: center;
    }

    .score-sidecard {
      width: 100%;
      border: 1px solid rgba(15, 23, 40, 0.06);
      border-radius: 20px;
      background: rgba(255, 255, 255, 0.92);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.6);
      padding: 14px 16px;
    }

    .mini-section + .mini-section {
      margin-top: 14px;
      padding-top: 14px;
      border-top: 1px solid rgba(15, 23, 40, 0.06);
    }

    .detail-panel {
      border: 1px solid rgba(15, 23, 40, 0.06);
      border-radius: 24px;
      background: rgba(255, 255, 255, 0.9);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.65);
      padding: 18px 20px;
    }

    .detail-group + .detail-group {
      margin-top: 16px;
      padding-top: 14px;
      border-top: 1px solid rgba(15, 23, 40, 0.06);
    }

    details.detail-group {
      border-radius: 18px;
      transition: background 160ms ease, border-color 160ms ease;
    }

    details.detail-group[open] {
      background: rgba(248, 250, 252, 0.72);
      border-color: rgba(15, 23, 40, 0.08);
    }

    .detail-summary {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 14px;
      margin: -6px -8px;
      padding: 8px;
      border-radius: 16px;
      cursor: pointer;
      list-style: none;
    }

    .detail-summary::-webkit-details-marker {
      display: none;
    }

    .detail-summary:hover {
      background: rgba(15, 23, 40, 0.04);
    }

    .detail-summary h3 {
      margin: 0;
    }

    .detail-summary::after {
      content: "+";
      display: inline-grid;
      width: 24px;
      height: 24px;
      place-items: center;
      flex: 0 0 auto;
      border-radius: 999px;
      background: rgba(15, 23, 40, 0.06);
      color: var(--muted);
      font-size: 16px;
      font-weight: 800;
      line-height: 1;
    }

    details.detail-group[open] > .detail-summary::after {
      content: "−";
    }

    .detail-content {
      padding-top: 14px;
    }

    .detail-group h3 {
      margin: 0 0 8px;
      font-size: 19px;
      font-weight: 700;
      letter-spacing: -0.02em;
    }

    .detail-group p {
      margin: 0 0 8px;
      font-size: 13px;
      font-weight: 600;
      line-height: 1.45;
    }

    .detail-group ul {
      margin: 0;
      padding-left: 18px;
    }

    .detail-group li {
      font-size: 14px;
      line-height: 1.45;
      margin: 2px 0;
      color: var(--ink);
    }

    .score-explainer {
      margin: 0;
      padding: 10px 12px;
      border-radius: 16px;
      border: 1px solid rgba(37, 99, 235, 0.08);
      background: rgba(248, 250, 252, 0.95);
      color: var(--ink);
      font-size: 13px;
      line-height: 1.4;
      font-weight: 600;
    }

    .score-breakdown {
      margin-top: 0;
      padding: 12px 14px;
      border-radius: 20px;
      border: 1px solid rgba(15, 23, 40, 0.06);
      background: rgba(247, 250, 252, 0.95);
    }

    .score-breakdown h3 {
      margin: 0 0 6px;
      font-size: 17px;
      font-weight: 700;
      letter-spacing: -0.02em;
    }

    .score-breakdown ul {
      margin: 0;
      padding-left: 18px;
    }

    .score-breakdown li {
      font-size: 14px;
      line-height: 1.45;
      color: var(--ink);
    }

    .score-breakdown .breakdown-note {
      margin: 0 0 8px;
      font-size: 12px;
      font-weight: 600;
      color: var(--muted);
    }

    .pillar-detail {
      margin: 6px 0;
      border: 1px solid rgba(15, 23, 40, 0.06);
      border-radius: 14px;
      background: #ffffff;
      overflow: hidden;
    }

    .pillar-summary {
      cursor: pointer;
      padding: 10px 12px;
      font-size: 14px;
      font-weight: 700;
      list-style: none;
    }

    .pillar-summary::-webkit-details-marker {
      display: none;
    }

    .pillar-summary::after {
      content: "Expand";
      float: right;
      font-size: 11px;
      font-weight: 700;
      color: var(--muted);
    }

    .pillar-detail[open] .pillar-summary::after {
      content: "Collapse";
    }

    .pillar-meta {
      margin: 0;
      padding: 0 12px 10px 28px;
    }

    .pillar-meta li {
      font-size: 12px;
      line-height: 1.45;
      color: var(--ink);
    }

    .metric-table-wrap {
      overflow-x: auto;
      border: 1px solid rgba(15, 23, 40, 0.06);
      border-radius: 16px;
      background: rgba(255,255,255,0.96);
    }

    .metric-table {
      width: 100%;
      border-collapse: collapse;
      min-width: 820px;
    }

    .metric-table th,
    .metric-table td {
      padding: 10px 12px;
      border-bottom: 1px solid rgba(15, 23, 40, 0.06);
      text-align: left;
      font-size: 12px;
      vertical-align: top;
    }

    .metric-table th {
      color: var(--muted);
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      background: rgba(247, 250, 252, 0.95);
    }

    .metric-table tr:last-child td {
      border-bottom: 0;
    }

    .metric-status {
      display: inline-flex;
      border-radius: 999px;
      padding: 3px 8px;
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      background: rgba(100, 116, 139, 0.12);
      color: var(--muted);
    }

    .metric-status.pass {
      background: rgba(22, 163, 74, 0.12);
      color: #15803d;
    }

    .metric-status.fail {
      background: rgba(220, 38, 38, 0.12);
      color: #b91c1c;
    }

    .metric-status.review {
      background: rgba(217, 119, 6, 0.12);
      color: #b45309;
    }

    .ring {
      width: 196px;
      height: 196px;
      border-radius: 50%;
      border: 5px solid rgba(23, 111, 118, 0.9);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      background:
        radial-gradient(circle at 50% 30%, rgba(23, 111, 118, 0.06) 0%, rgba(23, 111, 118, 0) 56%),
        rgba(255,255,255,0.98);
      box-shadow:
        inset 0 0 0 1px rgba(15, 23, 40, 0.03),
        0 8px 20px rgba(15, 23, 40, 0.04);
    }

    .ring .num {
      font-size: 60px;
      font-weight: 700;
      line-height: 1;
      margin: 0;
      letter-spacing: -1px;
      color: var(--ink);
    }

    .ring .label {
      margin: 8px 0 0;
      font-size: 17px;
      color: var(--ink);
      font-weight: 600;
      text-align: center;
    }

    .tier-box {
      background: rgba(248, 250, 252, 0.92);
      border: 1px solid rgba(15, 23, 40, 0.06);
      border-radius: 20px;
      padding: 14px 16px;
      min-height: 170px;
    }

    .tier-label {
      font-size: 15px;
      color: var(--muted);
      margin: 0 0 4px;
      font-weight: 600;
    }

    .tier-value {
      font-size: 24px;
      margin: 0 0 8px;
      font-weight: 700;
      letter-spacing: -0.02em;
    }

    .minor-label {
      font-size: 14px;
      color: var(--muted);
      margin: 0 0 3px;
      font-weight: 600;
    }

    .minor-value {
      font-size: 22px;
      margin: 0 0 8px;
      font-weight: 700;
    }

    .review-note {
      font-size: 15px;
      color: #7a1f1f;
      font-weight: 700;
      margin: 4px 0 0;
      padding: 10px 12px;
      border-radius: 14px;
      background: rgba(239, 68, 68, 0.10);
      border: 1px solid rgba(239, 68, 68, 0.14);
      line-height: 1.35;
    }

    .review-note.pass {
      color: #115e3b;
      background: rgba(16, 185, 129, 0.10);
      border-color: rgba(16, 185, 129, 0.14);
    }

    .review-note.review {
      color: #7a4b00;
      background: rgba(245, 158, 11, 0.12);
      border-color: rgba(245, 158, 11, 0.18);
    }

    .gate-alert {
      margin-top: 10px;
      padding: 10px 12px;
      border-radius: 14px;
      background: rgba(239, 68, 68, 0.06);
      border: 1px solid rgba(239, 68, 68, 0.12);
    }

    .gate-alert-title {
      margin: 0 0 8px;
      font-size: 11px;
      line-height: 1.2;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      font-weight: 900;
      color: #8b1e1e;
    }

    .gate-list {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-bottom: 8px;
    }

    .gate-chip {
      display: inline-flex;
      align-items: center;
      padding: 6px 10px;
      border-radius: 999px;
      background: rgba(239, 68, 68, 0.10);
      border: 1px solid rgba(239, 68, 68, 0.14);
      color: #7a1f1f;
      font-size: 13px;
      font-weight: 900;
      line-height: 1;
    }

    .gate-detail {
      margin-top: 8px;
      border: 1px solid rgba(239, 68, 68, 0.12);
      border-radius: 14px;
      background: rgba(255, 255, 255, 0.92);
      overflow: hidden;
    }

    .gate-summary {
      cursor: pointer;
      padding: 10px 12px;
      font-size: 13px;
      font-weight: 700;
      list-style: none;
      color: #7a1f1f;
    }

    .gate-summary::-webkit-details-marker {
      display: none;
    }

    .gate-summary::after {
      content: "Show rule";
      float: right;
      font-size: 11px;
      font-weight: 800;
      color: #a12b2b;
    }

    .gate-detail[open] .gate-summary::after {
      content: "Hide rule";
    }

    .gate-body {
      padding: 0 12px 12px;
    }

    .gate-body p {
      margin: 0 0 8px;
      font-size: 13px;
      line-height: 1.45;
      color: #000000;
      font-weight: 700;
    }

    .gate-code {
      margin: 0;
      padding: 10px 12px;
      border-radius: 12px;
      background: rgba(248, 250, 252, 0.98);
      border: 1px solid rgba(15, 23, 40, 0.06);
      font-size: 11px;
      line-height: 1.45;
      color: #000000;
      white-space: pre-wrap;
      word-break: break-word;
      font-family: "SFMono-Regular", "Menlo", "Consolas", monospace;
      font-weight: 700;
    }

    .actions {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      border-top: 1px solid rgba(15, 23, 40, 0.07);
      margin-top: 12px;
      padding-top: 10px;
    }

    .btn-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .btn {
      background: var(--button);
      color: #f9fbff;
      border: 1px solid var(--button-border);
      border-radius: 12px;
      padding: 9px 14px;
      font-size: 14px;
      font-weight: 700;
      min-width: 124px;
      text-align: center;
    }

    .footnote {
      margin: 0;
      font-size: 13px;
      line-height: 1.35;
      color: var(--muted);
      max-width: 470px;
    }

    @media (max-width: 1280px) {
      .brand-logo { width: min(220px, 100%); }
      .brand-mark { width: 78px; height: 78px; border-radius: 22px; }
      .brand-name { font-size: 56px; }
      .brand-tag { font-size: 12px; }
      .title { font-size: 34px; }
      .subtitle { font-size: 15px; }
      .card-head h2 { font-size: 30px; }
      .request { font-size: 15px; }
      .evidence { font-size: 16px; }
      .chip { font-size: 13px; }
      .layout { grid-template-columns: 220px minmax(0, 1fr); }
      .ring { width: 180px; height: 180px; }
      .ring .num { font-size: 54px; }
      .ring .label { font-size: 17px; }
      .tier-label, .minor-label { font-size: 13px; }
      .tier-value, .minor-value { font-size: 20px; }
      .review-note { font-size: 14px; }
      .detail-group h3 { font-size: 17px; }
      .detail-group li { font-size: 12px; }
      .btn { font-size: 12px; min-width: 116px; }
      .footnote { font-size: 11px; }
    }

    @media (max-width: 930px) {
      body { padding: 12px; }
      .trust-card { border-radius: 24px; padding: 16px; }
      .brand-bar { gap: 12px; margin-bottom: 12px; }
      .brand-logo { width: min(160px, 100%); }
      .brand-mark { width: 54px; height: 54px; border-radius: 16px; }
      .brand-name { font-size: 36px; letter-spacing: 0.05em; }
      .brand-tag { font-size: 11px; letter-spacing: 0.1em; }
      .title { font-size: 32px; }
      .subtitle { font-size: 15px; }
      .card-head { flex-direction: column; gap: 8px; }
      .card-head h2 { font-size: 32px; }
      .request { font-size: 15px; }
      .evidence { font-size: 16px; }
      .chip { font-size: 13px; }
      .layout { grid-template-columns: 1fr; gap: 16px; }
      .score-wrap { flex-direction: row; flex-wrap: wrap; align-items: stretch; }
      .ring { width: 160px; height: 160px; }
      .ring .num { font-size: 52px; }
      .ring .label { font-size: 17px; }
      .score-sidecard { flex: 1; min-width: 220px; }
      .tier-label, .minor-label { font-size: 13px; }
      .tier-value, .minor-value { font-size: 23px; }
      .review-note { font-size: 14px; }
      .detail-panel { border-radius: 22px; }
      .detail-group h3 { font-size: 20px; }
      .detail-group li { font-size: 14px; }
      .actions { flex-direction: column; align-items: stretch; }
      .btn-row { width: 100%; }
      .btn { flex: 1; min-width: 0; }
      .footnote { max-width: unset; font-size: 13px; }
    }
  </style>
</head>
<body>
  {% set ns = namespace(failed_metrics=0) %}
  {% set gate_ns = namespace(blocking_gates=[]) %}
  {% for m in metric_results %}
    {% if m.passed is sameas false %}
      {% set ns.failed_metrics = ns.failed_metrics + 1 %}
    {% endif %}
  {% endfor %}

  {% set display_risk_tier = deployment_risk_tier or risk_tier %}
  {% set pedigree = display_risk_tier | title %}
  {% if overall_status == "pass" %}
    {% set policy_text = "Gates Passed" %}
  {% elif overall_status == "fail" %}
    {% set policy_text = "Gates Blocked" %}
  {% else %}
    {% set policy_text = "Review Required" %}
  {% endif %}
  {% for gate, status in stage_gate_status.items() %}
    {% if status == "fail" %}
      {% set gate_ns.blocking_gates = gate_ns.blocking_gates + [gate | replace("_", " ") | title] %}
    {% endif %}
  {% endfor %}

  <div class="frame">
    <section class="trust-card">
      <div class="card-head">
        <div>
          <div class="brand-lockup">
            {% if brand_logo_src %}
            <img class="brand-logo" src="{{ brand_logo_src }}" alt="Kentro logo" />
            {% else %}
            <div style="display:flex; align-items:center; gap:18px;">
              <div class="brand-mark" aria-hidden="true"></div>
              <div class="brand-copy">
                <p class="brand-name">KENTRO</p>
              </div>
            </div>
            {% endif %}
            <p class="brand-tag">Answer Trust Review</p>
          </div>
        </div>
        <p class="evidence">Evidence Pack: {{ run_id }}</p>
      </div>

      <div class="chips">
        <span class="chip pass hint" title="This is the answer-level trust verdict for the current response.">{{ answer_verdict | replace("_", " ") | title if answer_verdict else policy_text }}</span>
        <span class="chip blue hint" title="This shows how complete the evidence pack is compared with the list of required artifacts for this run.">{{ artifact_signal.evidence_label }}</span>
        <span class="chip purple hint" title="Configured risk is the declared risk level for this use case. It is set in configuration and does not change based on the score.">Configured Risk {{ pedigree }}</span>
        <span class="chip amber hint" title="Traceability shows whether this run includes system context and telemetry fields that let you trace the result back to a specific governed system.">{{ artifact_signal.trace_label }}</span>
        <span class="chip sky hint" title="Blocker findings are the red-team findings severe enough to stop release at the current threshold, which means high and critical in this demo.">{{ artifact_signal.security_label }}</span>
        <span class="chip purple hint" title="Template version marker. If this chip is missing, the Databricks job is running an older workspace checkout or cached package.">Template {{ scorecard_template_version }}</span>
        {% if evidence_confidence and evidence_confidence.tier %}
        <span class="chip {% if evidence_confidence.tier == 'high' %}pass{% elif evidence_confidence.tier == 'medium' %}amber{% else %}sky{% endif %} hint" title="Evidence confidence reflects how much signal backs the answer trust score: dimensional coverage, claim sample size, modality diversity, and modality agreement. Low confidence downgrades a trusted verdict to use_caution.">Evidence Confidence: {{ evidence_confidence.tier | title }}</span>
        {% endif %}
      </div>

      <div class="layout">
        <div class="score-wrap">
          <div class="ring">
            <p class="num">{{ answer_trust_score_pct if answer_trust_score_pct is not none else "N/A" }}</p>
            <p class="label">Answer Trust</p>
          </div>
          <p class="ring-note hint" title="The displayed score combines a grounding sub-score (geometric mean of claim support and evidence sufficiency), a semantic sub-score (embedding output support), and a multiplicative contradiction penalty so that contradictions cannot be averaged away by strong grounding.">This score reflects confidence in this answer.</p>
          <div class="score-sidecard">
            <div class="mini-section">
              <p class="tier-label hint" title="Deployment risk is the declared risk category for the system or use case. It is chosen in configuration and represents the intended operating context.">Deployment Risk</p>
              <p class="tier-value">{{ display_risk_tier | title }}</p>

              <p class="minor-label hint" title="Control tier is derived from the worst failed control severity. Tier 1 is best, Tier 3 is worst.">Control Tier</p>
              <p class="minor-value">{{ risk_tier }}</p>
            </div>

            <div class="mini-section">
              <p class="minor-label hint" title="Answer verdict tells the user whether this specific answer should be trusted, used cautiously, or not trusted.">Answer Verdict</p>
              <p class="minor-value">{{ answer_verdict | replace("_", " ") | title if answer_verdict else "Unknown" }}</p>

              <p class="minor-label hint" title="Release readiness starts from the governance control score and applies penalties for failing metrics, blocker findings, and incomplete artifacts. It is distinct from the answer trust score shown in the main ring.">Release Readiness</p>
              <p class="minor-value">{{ card_score.display_score_pct if card_score.display_score_pct is not none else "N/A" }}</p>

              <p class="review-note{% if overall_status == "pass" %} pass{% elif overall_status == "needs_review" %} review{% endif %}">{{ card_score.status_note }}</p>
              {% if gate_ns.blocking_gates %}
              <div class="gate-alert">
                <p class="gate-alert-title hint" title="Blocking gates are the specific stage checks that failed and caused the release to be blocked.">Blocking Gates</p>
                <div class="gate-list">
                  {% for gate_name in gate_ns.blocking_gates %}
                  <span class="gate-chip">{{ gate_name }}</span>
                  {% endfor %}
                </div>
                {% for gate, status in stage_gate_status.items() %}
                  {% if status == "fail" %}
                  <details class="gate-detail">
                    <summary class="gate-summary">{{ gate | replace("_", " ") | title }}</summary>
                    <div class="gate-body">
                      {% if gate == "evaluation" %}
                      <p>The evaluation gate blocks only when the answer verdict is not trusted. Other metric failures are review items and are listed in the metric table.</p>
                      <pre class="gate-code">answer_verdict = "{{ answer_verdict }}"
failing_metric_count = {{ metric_summary.failed }}
evaluation = "fail" if answer_verdict == "not_trusted" else "needs_review" if failing_metric_count &gt; 0 else "pass"

{{ status | upper }}</pre>
                      {% elif gate == "redteam" %}
                      <p>The red-team gate fails when blocker-level findings are present for this risk tier, or when red-team evidence is required but missing.</p>
                      <pre class="gate-code">high_findings = redteam_summary["high"] + redteam_summary["critical"]
require_redteam = {{ "true" if redteam_gate_rules.require_redteam else "false" }}
block_on_high_severity = {{ "true" if redteam_gate_rules.block_on_high_severity else "false" }}
total_findings = {{ redteam_summary.total_findings if redteam_summary.total_findings is defined else (redteam_summary.low + redteam_summary.medium + redteam_summary.high + redteam_summary.critical) }}

redteam = "needs_review" if high_findings else "pass"
if require_redteam and total_findings == 0:
    redteam = "fail"
if block_on_high_severity and high_findings &gt; 0:
    redteam = "fail"

high_findings = {{ redteam_summary.high }} + {{ redteam_summary.critical }} = {{ redteam_summary.high + redteam_summary.critical }}
require_redteam = {{ "true" if redteam_gate_rules.require_redteam else "false" }}, total_findings = {{ redteam_summary.total_findings if redteam_summary.total_findings is defined else (redteam_summary.low + redteam_summary.medium + redteam_summary.high + redteam_summary.critical) }}
block_on_high_severity = {{ "true" if redteam_gate_rules.block_on_high_severity else "false" }}

{{ "true" if redteam_gate_rules.block_on_high_severity else "false" }} and {{ redteam_summary.high + redteam_summary.critical }} &gt; 0 -> {{ status | upper }}</pre>
                      {% elif gate == "documentation" %}
                      <p>The documentation gate fails review when the evidence pack is incomplete.</p>
                      <pre class="gate-code">documentation = "pass" if evidence_completeness &gt;= 90 else "needs_review"

{{ "%.0f"|format(evidence_completeness) }} &gt;= 90 -> {{ status | upper }}</pre>
                      {% elif gate == "monitoring" %}
                      <p>The monitoring gate reflects whether required monitoring evidence is available for the run.</p>
                      <pre class="gate-code">monitoring = "pass"</pre>
                      {% else %}
                      <p>This gate is controlled by the stage-gate policy for the current risk tier.</p>
                      <pre class="gate-code">{{ gate }} = "{{ status }}"</pre>
                      {% endif %}
                    </div>
                  </details>
                  {% endif %}
                {% endfor %}
              </div>
              {% endif %}
            </div>
          </div>
        </div>

        <div class="detail-panel">
          <div class="detail-group">
            <h3>Why This Verdict</h3>
            <ul>
              <li>Answer trust score: {{ answer_trust_score_pct if answer_trust_score_pct is not none else "N/A" }} — grounding sub-score (geometric mean of claim support and evidence sufficiency) combined with semantic support and penalised multiplicatively by the contradiction rate.</li>
              {% if evidence_confidence and evidence_confidence.tier %}
              <li>Evidence confidence: <strong>{{ evidence_confidence.tier | title }}</strong> — measured {{ evidence_confidence.dimensional_coverage }}/4 answer-truth dimensions{% if evidence_confidence.claim_count is not none %} across {{ evidence_confidence.claim_count }} extracted claim(s){% endif %}{% if evidence_confidence.modality_diversity %} with dual-modality support{% if evidence_confidence.modality_disagreement is not none %} (|tfidf−embedding| = {{ "%.2f"|format(evidence_confidence.modality_disagreement) }}){% endif %}{% else %} with single-modality support{% endif %}.</li>
              {% endif %}
              <li>Claim support rate: {{ answer_truth_summary.claim_support_rate if answer_truth_summary.claim_support_rate is not none else "N/A" }}.</li>
              <li>Unsupported claim rate: {{ answer_truth_summary.unsupported_claim_rate if answer_truth_summary.unsupported_claim_rate is not none else "N/A" }}.</li>
              <li>Contradiction rate: {{ answer_truth_summary.contradiction_rate if answer_truth_summary.contradiction_rate is not none else "N/A" }}.</li>
              <li>Evidence sufficiency score: {{ answer_truth_summary.evidence_sufficiency_score if answer_truth_summary.evidence_sufficiency_score is not none else "N/A" }}.</li>
              <li>Bias risk: {{ bias_assessment.risk | title if bias_assessment.risk else "Unknown" }}{% if bias_assessment.signal_terms %} ({{ bias_assessment.signal_terms | join(", ") }}){% endif %}.</li>
              <li>Trust z-score: {{ trust_score_z if trust_score_z is not none else "N/A" }} keeps the historical cohort comparison for audit and benchmarking.</li>
              <li>Governance score: {{ card_score.control_score_pct if card_score.control_score_pct is not none else "N/A" }} from the four trust pillars.</li>
              <li>Security {{ "%.0f"|format(pillar_scores.security * 100) if pillar_scores else "N/A" }}%, Reliability {{ "%.0f"|format(pillar_scores.reliability * 100) if pillar_scores else "N/A" }}%, Transparency {{ "%.0f"|format(pillar_scores.transparency * 100) if pillar_scores else "N/A" }}%, Governance {{ "%.0f"|format(pillar_scores.governance * 100) if pillar_scores else "N/A" }}%.</li>
              <li>Evidence completeness: {{ "%.0f"|format(evidence_completeness) }}%.</li>
              <li>Governance blockers are still shown separately and can still change the final decision status.</li>
            </ul>
          </div>

          <details class="detail-group">
            <summary class="detail-summary"><h3>Answer Checks</h3></summary>
            <div class="detail-content">
              <ul>
                {% for reason in answer_reasons %}
                <li>{{ reason }}</li>
                {% endfor %}
              </ul>
            </div>
          </details>

          <details class="detail-group">
            <summary class="detail-summary"><h3>All Evaluation Metrics - Pass/Fail</h3></summary>
            <div class="detail-content">
              <p class="breakdown-note">Every configured metric is available here. Passing metrics support the score, failed metrics require review, and unavailable metrics are informational.</p>
              <div class="metric-table-wrap">
                <table class="metric-table">
                  <thead>
                    <tr>
                      <th>Metric</th>
                      <th>Value</th>
                      <th>Threshold</th>
                      <th>Status</th>
                      <th>Strength</th>
                      <th>Details</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for m in metric_results %}
                    <tr>
                      <td>{{ m.metric_id }}</td>
                      <td>{{ m.value if m.value is not none else "N/A" }}</td>
                      <td>{{ m.threshold if m.threshold is not none else "N/A" }}</td>
                      <td>
                        {% if m.passed is sameas true %}
                        <span class="metric-status pass">Pass</span>
                        {% elif m.passed is sameas false %}
                        <span class="metric-status fail">Review</span>
                        {% else %}
                        <span class="metric-status review">N/A</span>
                        {% endif %}
                      </td>
                      <td>{{ metric_strength.get(m.metric_id, "proxy") | title }}</td>
                      <td>
                        {% if m.metric_id == "llm_contradiction_judge" %}
                          {% if m.details.data_basis == "llm_judged" %}
                          LLM judge. Model: {{ m.details.model | default("unknown") }}. Contradictory claims: {{ m.details.yes_count | default(0) }}/{{ m.details.claim_count | default("N/A") }}. Unknown: {{ m.details.unknown_count | default(0) }}.
                          {% else %}
                          Advisory judge unavailable: {{ m.details.reason | default("no reason provided") }}.
                          {% endif %}
                        {% elif m.metric_id == "llm_claim_entailment" %}
                          {% if m.details.data_basis == "llm_judged" %}
                          LLM judge. Model: {{ m.details.model | default("unknown") }}. Entailed claims: {{ m.details.yes_count | default(0) }}/{{ m.details.claim_count | default("N/A") }}. Unknown: {{ m.details.unknown_count | default(0) }}.
                          {% else %}
                          Advisory judge unavailable: {{ m.details.reason | default("no reason provided") }}.
                          {% endif %}
                        {% elif m.metric_id == "context_relevance_embedding_coverage" %}
                          Relevant chunks: {{ m.details.relevant_chunk_count | default("N/A") }}/{{ m.details.total_chunk_count | default("N/A") }}.
                        {% elif m.details.data_basis %}
                          {{ m.details.data_basis | replace("_", " ") | title }}
                        {% else %}
                          -
                        {% endif %}
                      </td>
                    </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            </div>
          </details>

          <details class="detail-group">
            <summary class="detail-summary"><h3>Traceability</h3></summary>
            <div class="detail-content">
              <ul>
                <li>Run ID: {{ run_id }}</li>
                <li>System: {{ system_context.system_id if system_context else "n/a" }} | Environment: {{ system_context.environment if system_context else "n/a" }}</li>
                <li>System hash: {{ system_context.system_hash[:12] ~ "..." if system_context and system_context.system_hash else "n/a" }}</li>
                <li>{{ artifact_signal.trace_label }} | {{ artifact_signal.evidence_label }}</li>
              </ul>
            </div>
          </details>

          <details class="detail-group">
            <summary class="detail-summary"><h3>Security Context</h3></summary>
            <div class="detail-content">
              <ul>
                <li>Blocking threshold: {{ severity_threshold | upper }}.</li>
                <li>Blocker findings: {{ redteam_summary.high + redteam_summary.critical }} (High: {{ redteam_summary.high }}, Critical: {{ redteam_summary.critical }}).</li>
                <li>Passed or non-blocking findings: {{ redteam_summary.medium + redteam_summary.low }} (Medium: {{ redteam_summary.medium }}, Low: {{ redteam_summary.low }}).</li>
                <li>Evaluation checks passed: {{ metric_summary.passed }} of {{ metric_summary.total }}.</li>
              </ul>
            </div>
          </details>

          <details class="detail-group">
            <summary class="detail-summary"><h3>Baseline Trust Inputs</h3></summary>
            <div class="detail-content">
              <p class="breakdown-note">Expand a pillar to see the formula, weighting, and contribution to the trust score.</p>
              <ul class="pillar-meta">
                <li>Weighting policy: Security {{ "%.0f"|format(weighting_rationale.security * 100) }}%, Reliability {{ "%.0f"|format(weighting_rationale.reliability * 100) }}%, Transparency {{ "%.0f"|format(weighting_rationale.transparency * 100) }}%, Governance {{ "%.0f"|format(weighting_rationale.governance * 100) }}%.</li>
              </ul>
              {% if pillar_breakdowns %}
              {% for pillar_name, breakdown in pillar_breakdowns.items() %}
              <details class="pillar-detail">
                <summary class="pillar-summary">{{ pillar_name | title }}: {{ "%.0f"|format(breakdown.pillar_score * 100) }}%</summary>
                <ul class="pillar-meta">
                  <li>Formula: {{ breakdown.formula }}</li>
                  {% if breakdown.redteam_pass_rate is defined %}
                  <li>Why it looks different: security blends weighted controls with red-team results.</li>
                  <li>Weighted controls: {{ breakdown.control_weight_passed|round(0)|int }} of {{ breakdown.control_weight_total|round(0)|int }} control points passed = {{ "%.0f"|format(breakdown.control_pass_rate * 100) if breakdown.control_pass_rate is not none else "N/A" }}%</li>
                  {% else %}
                  <li>Why it is {{ "%.0f"|format(breakdown.pillar_score * 100) }}%: this pillar uses weighted control points, not a flat control count.</li>
                  {% endif %}
                  {% if breakdown.redteam_pass_rate is defined %}
                  <li>Controls passed: {{ breakdown.control_passed }}/{{ breakdown.control_total }}</li>
                  <li>Controls alone: {{ "%.0f"|format(breakdown.control_pass_rate * 100) if breakdown.control_pass_rate is not none else "N/A" }}%</li>
                  <li>Red-team result: {{ "%.0f"|format(breakdown.redteam_pass_rate * 100) }}%</li>
                  {% else %}
                  <li>Controls passed: {{ breakdown.control_passed }}/{{ breakdown.control_total }}</li>
                  <li>Controls checked: {{ breakdown.control_total }}</li>
                  {% endif %}
                  <li>How much this matters: this pillar is {{ "%.0f"|format(breakdown.trust_weight * 100) }}% of the total trust score.</li>
                  <li>Contribution to the final trust score: {{ "%.0f"|format(breakdown.trust_contribution * 100) }} points out of 100.</li>
                </ul>
              </details>
              {% endfor %}
              {% else %}
              <ul>
                <li>Pillar scores are not available for this run.</li>
              </ul>
              {% endif %}
            </div>
          </details>

          <details class="detail-group">
            <summary class="detail-summary"><h3>Governance Flags</h3></summary>
            <div class="detail-content">
              <ul>
                <li>Decision status: {{ overall_status | replace("_", " ") | title }}</li>
                <li>Release decision: {{ go_no_go | upper }}</li>
                <li>Stage gates: {% for gate, status in stage_gate_status.items() %}{{ gate | replace("_", " ") | title }}={{ status | upper }}{% if not loop.last %}; {% endif %}{% endfor %}</li>
                <li>{{ card_score.status_note }}</li>
              </ul>
            </div>
          </details>
        </div>
      </div>

      <div class="actions">
        <p class="footnote">This card travels with the output as an auditable evidence link for governance review.</p>
      </div>
    </section>
  </div>
</body>
</html>
